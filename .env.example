# =============================================================================
# Agentic AI Honeypot - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control!
# =============================================================================

# =============================================================================
# API Security
# =============================================================================
# API key required for all incoming requests
API_KEY=your_secure_api_key_here

# =============================================================================
# LLM Configuration (OpenRouter)
# =============================================================================
# Get your free API key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =============================================================================
# Callback Configuration
# =============================================================================
# Webhook URL for reporting captured intelligence
GUVI_CALLBACK_URL=https://hackathon.guvi.in/api/updateHoneyPotFinalResult

# =============================================================================
# MongoDB Atlas Configuration
# =============================================================================
# Get your connection string from MongoDB Atlas dashboard
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?options
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/honeypot?retryWrites=true&w=majority

# =============================================================================
# Application Settings
# =============================================================================
# Server port (default: 8000)
PORT=8000

# Debug mode (set to False in production)
DEBUG=True

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
